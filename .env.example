# Ring Detector Configuration
# Copy to .env and fill in your values

# PostgreSQL + pgvector
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ring
DB_USER=postgres
DB_PASSWORD=changeme

# Ring Doorbell
RING_TOKEN_PATH=./tokens/token.cache
RING_FCM_CREDENTIALS_PATH=./tokens/fcm_credentials.json
RING_CAMERA_NAME=Front Door

# Seconds without motion before someone is considered "departed"
DEPARTURE_TIMEOUT=300
# Seconds to ignore duplicate motion events from same camera
MOTION_COOLDOWN=30

# Attach snapshot images to notifications (true/false)
NTFY_ATTACH_SNAPSHOT=true

# Storage (NAS archive)
ARCHIVE_DIR=/mnt/nas/ring_archive

# Notifications (ntfy)
NTFY_URL=https://ntfy.sh/your-ring-topic

# ML Models
YOLO_MODEL_PATH=./models/yolov8m.pt
TORCH_DEVICE=cuda:0
BATCH_SIZE=50

# Scene Captioning (Ollama + Gemma 3 4B)
CAPTIONER_ENABLED=false
OLLAMA_URL=http://localhost:11434
CAPTIONER_MODEL=gemma3:4b
CAPTIONER_TIMEOUT=30

# pgAdmin (for docker compose)
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=changeme
