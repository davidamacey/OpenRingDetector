# Ring Detector Configuration
# Copy to .env and fill in your values

# PostgreSQL + pgvector
DB_HOST=localhost
DB_PORT=9550
DB_NAME=ring
DB_USER=postgres
DB_PASSWORD=changeme

# Ring Doorbell
RING_TOKEN_PATH=./tokens/token.cache
RING_FCM_CREDENTIALS_PATH=./tokens/fcm_credentials.json
RING_CAMERA_NAME=Front Door

# Primary departure detection is FOV-presence-driven (motion event + YOLO check).
# This timer is a safety-net fallback for when the vehicle leaves and no further motion fires.
DEPARTURE_TIMEOUT=7200
# Number of consecutive motion events without vehicle in FOV before departure is declared
DEPARTURE_MISS_THRESHOLD=2
# Seconds before sending "Unknown Visitor" push (window for vehicle detection to cancel it)
UNKNOWN_VISITOR_DELAY=120
# Seconds to ignore duplicate motion events from same camera
MOTION_COOLDOWN=30

# Attach snapshot images to notifications (true/false)
NTFY_ATTACH_SNAPSHOT=true

# Storage (NAS archive)
ARCHIVE_DIR=/mnt/nas/ring_archive

# Notifications (ntfy)
NTFY_URL=http://localhost:9552/ring_cam

# ML Models
YOLO_MODEL_PATH=./models/yolo26m.pt
TORCH_DEVICE=cuda:0
BATCH_SIZE=50

# Face Detection Models (SCRFD-10G + ArcFace w600k_r50)
# Run: bash scripts/download_face_models.sh to download these
SCRFD_MODEL_PATH=./models/scrfd_10g_bnkps.onnx
ARCFACE_MODEL_PATH=./models/arcface_w600k_r50.onnx

# Scene Captioning (Ollama + Gemma 3 4B)
CAPTIONER_ENABLED=false
OLLAMA_URL=http://localhost:9551
CAPTIONER_MODEL=gemma3:4b
CAPTIONER_TIMEOUT=30

# Face Detection + Recognition
ENABLE_FACE_DETECTION=true
# Cosine similarity cutoff for face matching (0.0–1.0, higher = stricter)
FACE_MATCH_THRESHOLD=0.6
# Minimum face bounding-box dimension in pixels to consider (filters tiny/blurry faces)
FACE_MIN_SIZE=50
# Backend: "local" (ONNX Runtime, default) or "triton" (calls triton-api HTTP API)
FACE_BACKEND=local
# triton-api base URL — only used when FACE_BACKEND=triton
# Falls back to local mode automatically if Triton is unreachable
TRITON_HTTP_URL=http://localhost:8000

# Video Analysis (analyze full recording instead of single snapshot)
VIDEO_ANALYSIS_ENABLED=true
# Extract every Nth frame (~1fps at 30fps Ring video)
VIDEO_FRAME_INTERVAL=30
# Maximum frames to analyze per video
VIDEO_MAX_FRAMES=15
# Seconds to wait for Ring to process the video server-side
VIDEO_WAIT_TIMEOUT=60
# Seconds between retry attempts when waiting for video
VIDEO_RETRY_DELAY=5
